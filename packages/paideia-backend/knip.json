{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignore": [
    "src/payload-generated-schema.ts",
    "**/*.json",
    "scripts/**",
    "tests/**",
    "**/*.test.ts",
    "src/utils/types.ts"
  ],
  "tags": [
    "-knipignore"
  ],
  "ignoreIssues": {
    "**": ["binaries", "duplicates", "unlisted", "types"],
    "**/*.test.ts": ["files"]
  }
}
