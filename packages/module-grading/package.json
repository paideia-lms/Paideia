{
  "name": "@paideia/module-grading",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate:payload": "PAYLOAD_CONFIG_PATH=src/payload.config.ts bun payload generate:types && PAYLOAD_CONFIG_PATH=src/payload.config.ts bun payload generate:db-schema",
    "migrate:create": "PAYLOAD_CONFIG_PATH=src/payload.config.ts bun payload migrate:create",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paideia/module-course": "workspace:*",
    "@paideia/module-enrolment": "workspace:*",
    "@paideia/module-infrastructure": "workspace:*",
    "@paideia/module-user": "workspace:*",
    "@paideia/shared": "workspace:*",
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/storage-s3": "^3.79.0",
    "es-toolkit": "^1.33.0",
    "payload": "^3.79.0",
    "typescript-result": "^3.5.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@orpc/server": "^1.4.3",
    "typescript": "^5.8.2"
  }
}
