{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"apps/paideia/server/**",
			"apps/paideia/src/**",
			"apps/paideia/app/**",
			"!apps/paideia/server/payload-types.ts",
			"!apps/paideia/server/vfs.ts",
			"!apps/paideia/src/migrations",
			"!**/dist",
			"!**/*.json",
			"!**/*.config.ts",
			"!node_modules",
			"!apps/paideia/src/payload-generated-schema.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useTemplate": "off",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"nuqs": {
								"importNames": ["useQueryState"],
								"message": "useQueryState from nuqs should not be used directly. Use useNuqsSearchParams from app/utils/search-params-utils.ts instead."
							}
						}
					}
				}
			},
			"suspicious": {
				"noTsIgnore": "off",
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
