{
	"name": "paideia",
	"description": "Paideia LMS - Simple, Robust, and Lightweight Learning Management System in a Single Executable",
	"version": "0.7.15",
	"keywords": [
		"paideia",
		"lms",
		"learning",
		"management",
		"system",
		"education"
	],
	"private": true,
	"sideEffects": false,
	"type": "module",
	"author": "Hananoshika Yomaru",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/paideia-lms/paideia"
	},
	"homepage": "https://github.com/paideia-lms/paideia",
	"scripts": {
		"build": "bun scripts/build.ts",
		"start": "./dist/paideia",
		"start:dev": "docker compose -f ../../docker-compose.yml up -d",
		"dev": "bun --parallel dev:*",
		"dev:server": "NODE_ENV=development bun --watch ./server/index.ts",
		"dev:frontend": "bun react-router --watch typegen",
		"lint": "biome check --write --log-level=error --diagnostic-level=error .",
		"lint:project": "bun scripts/lint-project.ts",
		"test:all": "bun test $(find . -type f -name \"*.test.ts\" -not -path \"./node_modules/*\") 2>&1 | tee tests/reports/$(date +\"%Y-%m-%d\").log; bun scripts/process-test-log.ts tests/reports/$(date +\"%Y-%m-%d\").log",
		"migrate:create": "bun scripts/clean-s3.ts && PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:create",
		"migrate:status": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:status",
		"migrate:up": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate",
		"migrate:down": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:down",
		"migrate:refresh": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:refresh --force-accept-warning && bun scripts/clean-s3.ts",
		"migrate:reset": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:reset",
		"migrate:fresh": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile migrate:fresh --force-accept-warning && bun scripts/clean-s3.ts",
		"docker:build": "docker build -t paideia:$(node -p \"require('./package.json').version\") .",
		"docker:update": "docker compose -f ../../docker-compose.yml -f ../../docker-compose.paideia.yml pull",
		"docker:run": "docker compose -f ../../docker-compose.yml -f ../../docker-compose.paideia.yml up -d",
		"docker:prune": "docker image prune -f",
		"typegen": "PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile generate:types && PAYLOAD_CONFIG_PATH=server/payload.config.ts bunx payload --disable-transpile generate:db-schema && react-router typegen",
		"typecheck": "tsgo --noEmit --extendedDiagnostics",
		"knip": "knip",
		"dedupe": "bunx nypm dedupe"
	},
