{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["@react-router/node", "vite/client", "bun"],
		"rootDirs": [".", "./.react-router/types"],
		"jsx": "react-jsx",
		"allowJs": true,
		"paths": {
			"app/*": ["./app/*"],
			"server/*": ["./server/*"],
			"~/*": ["./app/*"],
			"@mantine/form/lib/paths.types": ["./node_modules/@mantine/form/lib/paths.types"]
		}
	},
	"include": ["./.react-router/types", "."],
	"exclude": ["node_modules", "dist", "src/payload-generated-schema.ts", "src/migrations", "opensrc"]
}
