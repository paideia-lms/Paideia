{
	"name": "paideia-monorepo",
	"private": true,
	"type": "module",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"dev": "bun run --cwd apps/paideia dev",
		"build": "bun run --cwd apps/paideia build",
		"lint": "bun run --cwd apps/paideia lint",
		"lefthook:install": "lefthook install",
		"dedupe": "bunx nypm dedupe",
		"lint:project": "bun packages/paideia-backend/scripts/lint-project.ts",
		"push-docker": "bun scripts/push-docker.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.3",
		"@types/request-ip": "^0.0.41",
		"@total-typescript/ts-reset": "^0.6.1",
		"@biomejs/biome": "2.3.10",
		"type-fest": "^5.4.4",
		"@typescript/native-preview": "^7.0.0-dev.20260305.1",
		"lefthook": "^2.1.2",
		"knip": "^5.85.0",
		"typescript": "^5.9.3"
	}
}
